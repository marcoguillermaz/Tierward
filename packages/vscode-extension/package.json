{
  "name": "tierward-vscode",
  "displayName": "Tierward",
  "description": "Editor-native governance surfaces for Tierward: doctor health, skill/rule registry, and audit findings inside VS Code.",
  "version": "0.0.1",
  "publisher": "marcoguillermaz",
  "icon": "resources/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/marcoguillermaz/tierward.git",
    "directory": "packages/vscode-extension"
  },
  "bugs": {
    "url": "https://github.com/marcoguillermaz/tierward/issues"
  },
  "homepage": "https://github.com/marcoguillermaz/tierward/tree/main/packages/vscode-extension#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "claude",
    "claude code",
    "governance",
    "tierward"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:.claude/settings.json",
    "onView:tierward.governance"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tierward-governance",
          "title": "Tierward",
          "icon": "resources/tierward.svg"
        }
      ]
    },
    "views": {
      "tierward-governance": [
        {
          "id": "tierward.governance",
          "name": "Governance"
        }
      ]
    },
    "commands": [
      {
        "command": "tierward.showDoctorReport",
        "title": "Tierward: Run Doctor Report"
      },
      {
        "command": "tierward.refreshGovernance",
        "title": "Tierward: Refresh Governance",
        "icon": "$(refresh)"
      },
      {
        "command": "tierward.runSkill",
        "title": "Tierward: Run Skill in Claude Code"
      },
      {
        "command": "tierward.runSkillByName",
        "title": "Tierward: Run Skill (by name)"
      },
      {
        "command": "tierward.runSkillInCc",
        "title": "Run in Claude Code",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "tierward.refreshGovernance",
          "when": "view == tierward.governance",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "tierward.runSkillInCc",
          "when": "view == tierward.governance && viewItem == tierward.skill.invocable",
          "group": "inline"
        },
        {
          "command": "tierward.runSkillInCc",
          "when": "view == tierward.governance && viewItem == tierward.skill.invocable",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "tierward.runSkillByName",
          "when": "false"
        },
        {
          "command": "tierward.runSkillInCc",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Tierward",
      "properties": {
        "tierward.cliPath": {
          "type": "string",
          "default": "tierward",
          "description": "Command used to invoke the Tierward CLI. Override with an absolute path if the CLI is not on PATH."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "pretest": "node esbuild.js",
    "test": "node --test \"test/**/*.test.js\"",
    "vscode:prepublish": "node esbuild.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "typescript": "^5.6.0"
  }
}
