{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "Co-authored-by: Claude <noreply@anthropic.com>",
    "pr": "AI-assisted: requires human review before merging"
  },
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push origin main*)",
      "Bash(rm -rf /*)",
      "Bash(npm publish*)",
      "Bash(DROP DATABASE*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/team-settings-enforcement.mjs\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/tierward-governance-gate.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ \"$stop_hook_active\" = \"1\" ] && exit 0; [TEST_GUARD]OUT=$([TEST_COMMAND] 2>&1); CODE=$?; [ \"$CODE\" -ne 0 ] && { echo \"$OUT\" >&2; echo '{\"decision\": \"block\", \"reason\": \"Tests must pass before declaring complete.\"}'; }; exit 0",
            "timeout": 300
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$(date -u +%Y-%m-%dT%H:%M:%SZ) WRITE $CLAUDE_TOOL_INPUT_FILE_PATH\" >> /tmp/claude-audit.log",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "LAST=$(cat \"$CLAUDE_PROJECT_DIR/.claude/session/last-arch-audit\" 2>/dev/null || echo 0); NOW=$(date +%s); DIFF=$((NOW - LAST)); if [ $DIFF -gt 604800 ]; then DAYS=$((DIFF / 86400)); LAST_DATE=$([ $LAST -eq 0 ] && echo 'never' || date -r $LAST '+%Y-%m-%d' 2>/dev/null || date -d \"@$LAST\" '+%Y-%m-%d' 2>/dev/null || echo 'unknown'); echo \"\u26a0\ufe0f  Arch audit overdue \u2014 last run: $LAST_DATE (${DAYS}d ago). Run /arch-audit to check compliance with latest Anthropic docs.\"; fi",
            "async": true
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f .claude/CLAUDE.local.md ] && echo '\ud83d\udccc CLAUDE.local.md exists \u2014 re-read it to restore active overrides.' || true",
            "async": true
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat >> /tmp/claude-instructions-$(date +%Y%m%d).log 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/tierward-capture-approval.mjs\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
